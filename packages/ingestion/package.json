{
  "name": "@worldcup/ingestion",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "ingest:fixtures": "tsx src/scrapers/scrape-fixtures.ts",
    "ingest:teams": "tsx src/scrapers/scrape-teams.ts",
    "ingest:players": "tsx src/scrapers/scrape-players.ts",
    "ingest:player-profiles": "tsx src/scrapers/scrape-player-profiles.ts",
    "ingest:match-stats": "tsx src/scrapers/scrape-match-stats.ts",
    "ingest:venues": "tsx src/scrapers/scrape-venues.ts",
    "ingest:assets": "tsx src/assets/download-all.ts",
    "ingest:player-photos": "tsx src/assets/download-player-photos.ts",
    "ingest:player-photos:wikimedia": "tsx src/assets/download-wikimedia-player-photos.ts",
    "ingest:all": "tsx src/ingest-all.ts",
    "import:openfootball": "tsx src/import-openfootball.ts",
