{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "types": ["node"],
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@worldcup/shared": ["../../packages/shared/src/index.ts"],
      "@worldcup/shared/*": ["../../packages/shared/src/*"],
      "@worldcup/ui": ["../../packages/ui/src/index.ts"],
      "@/*": ["./src/*"]
    }
  },
  "include": ["src", "vite.config.ts"]
}
