# ============================================================
#  Copa26 Command Center — example environment
#  Copy to .env.local (gitignored) and adjust.
# ============================================================

# --- Local API (must stay on localhost / loopback) ---
LOCAL_API_HOST=127.0.0.1
LOCAL_API_PORT=8787

# --- Web (Vite dev server) ---
WEB_PORT=5173
# The web app talks to the local API through Vite's dev proxy at /api,
# so this only matters if you change the API port above.
VITE_LOCAL_API_URL=http://127.0.0.1:8787

# --- Local database (optional SQLite file, gitignored) ---
# libsql / Drizzle uses a file: URL pointing inside ./local-db
DATABASE_URL=file:./local-db/worldcup.sqlite
DATABASE_AUTH_TOKEN=

# --- Family pool / AI provider ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# --- Production sync / monitoring ---
CRON_SECRET=
RESULTS_SOURCE_URL=
# Optional Vercel KV / Upstash Redis REST vars for durable usage counters.
KV_REST_API_URL=
KV_REST_API_TOKEN=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Ingestion (public-pages-only scraping, see scraper_policy.md) ---
# A descriptive, honest User-Agent. Never spoof or rotate this.
INGEST_USER_AGENT=FIFA-Private-Dashboard/0.1 (personal local research; respects robots.txt)
# Conservative random delay window between requests, in milliseconds.
INGEST_MIN_DELAY_MS=4000
INGEST_MAX_DELAY_MS=10000
# Hard cap on concurrency. Do not raise above 1.
INGEST_MAX_CONCURRENCY=1
# Set to "1" to force re-fetch even when a cached copy exists (default: use cache).
INGEST_FORCE_REFETCH=0
# Run Playwright headless. No proxy / no stealth settings are supported on purpose.
INGEST_HEADLESS=1

# --- Cron Toggles ---
ENABLE_DATA_SYNC_CRON=false
ENABLE_RESULTS_SYNC_CRON=false
ENABLE_SIMULATE_LIVE_CRON=false
ENABLE_JOURNALIST_CRON=false
