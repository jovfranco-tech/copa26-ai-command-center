# ============================================================
#  FIFA Private World Cup Dashboard — LOCAL ONLY
#  Raw downloads stay local-only. The app may include optimized static
#  derivatives under apps/web/static for the private deployment.
# ============================================================

# --- MANDATORY local-only / private exclusions ---
private-assets/
local-db/
scraped-cache/
.env.local
*.sqlite
*.sqlite-journal
*.sqlite-wal
*.sqlite-shm
*.db
reports/*.json

# --- Environment ---
.env
.env.*
!.env.example

# --- Dependencies ---
node_modules/
.pnpm-store/

# --- Build output ---
dist/
build/
*.tsbuildinfo
.vite/

# --- Logs / caches ---
*.log
npm-debug.log*
pnpm-debug.log*
.eslintcache
coverage/
.tmp-intel-packs/

# --- Editor / OS ---
.DS_Store
.idea/
.vscode/*
!.vscode/extensions.json
*.local

# --- Playwright (browsers download outside repo, but ignore any local output) ---
test-results/
playwright-report/
.playwright/
# Visual baselines: keep only the CI (linux) set; never commit local-OS baselines.
**/*-snapshots/*-darwin.png
**/*-snapshots/*-win32.png

# --- Vercel (project link metadata; deploys are local-only-aware) ---
.vercel/
.vercel

# --- Matchday: live results working copy (fill from results.example.json) ---
# The committed source of truth is the dataset; results.json is a throwaway input.
/results.json
.env*.local
